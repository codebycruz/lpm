---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.published.valueOf() - a.data.published.valueOf(),
);
---

<Layout title="Blog">
    <div class="w-full max-w-3xl mx-auto px-4 py-12">
        <div class="mb-8">
            <p class="text-blue-400 text-sm font-semibold uppercase tracking-widest mb-2">Updates</p>
            <h1 class="text-4xl font-bold">Blog</h1>
        </div>
        <ul
            class="flex flex-col gap-4 divide-y divide-gray-200 dark:divide-gray-800"
        >
            {
                posts.map((post) => (
                    <li>
                        <a
                            href={`/blog/${post.id}`}
                            class="flex flex-col gap-1 py-4 group"
                        >
                            <span class="text-xl font-medium group-hover:text-blue-500 transition-colors">
                                {post.data.title}
                            </span>
                            <span class="text-base text-gray-500 dark:text-gray-400">
                                {post.data.author} &middot;{" "}
                                {post.data.published.toLocaleDateString(
                                    "en-US",
                                    {
                                        year: "numeric",
                                        month: "long",
                                        day: "numeric",
                                    },
                                )}
                            </span>
                            {post.data.description && (
                                <div class="mt-1 text-sm text-gray-500 dark:text-gray-400 leading-relaxed line-clamp-2">
                                    {post.data.description}
                                </div>
                            )}
                        </a>
                    </li>
                ))
            }
        </ul>
    </div>
</Layout>
