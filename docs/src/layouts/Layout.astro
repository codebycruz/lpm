---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import CodeBlocks from "../components/CodeBlocks.tsx";
import { SITE_URL } from "../data/info";
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
	hideFooter?: boolean;
	hideGlow?: boolean;
	hasTabs?: boolean;
}

const DEFAULT_DESCRIPTION =
	"Lde is an open-source project providing easy accessibility to a Lua runtime alongside intuitive package management for dependencies.";

const {
	title,
	description = DEFAULT_DESCRIPTION,
	hideFooter = false,
	hideGlow = false,
	hasTabs = false,
} = Astro.props;
const pageTitle = title ? `${title} - lde` : "lde";
const ogSlug = Astro.url.pathname.replace(/^\/|\/$/g, "") || "index";
const ogImage = `${SITE_URL}/og/${ogSlug}.png`;
---

<html lang="en" class="overflow-y-scroll">
	<head>
		<meta charset="utf-8" />
		<script is:inline>
			(function () {
				const stored = localStorage.getItem("theme");
				const prefersDark = window.matchMedia(
					"(prefers-color-scheme: dark)",
				).matches;
				if (stored === "dark" || (!stored && prefersDark)) {
					document.documentElement.classList.add("dark");
				}
			})();
		</script>
		<link rel="icon" type="image/svg+xml" href="/lde-text.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="lde" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:url" content={SITE_URL + Astro.url.pathname} />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<link
			rel="alternate"
			type="application/rss+xml"
			title="lde blog"
			href="/rss.xml"
		/>
	</head>
	<body
		class="relative overflow-x-hidden bg-white dark:bg-gray-950 text-black dark:text-white flex flex-col min-h-screen lg:min-w-fit"
	>
		<!-- Ambient page glow (hidden on index which has its own hero fx) -->
		{!hideGlow && (
			<div class="absolute inset-x-0 top-0 pointer-events-none select-none" aria-hidden="true">
				<div class="absolute top-[-400px] left-1/2 -translate-x-1/2 w-[800px] h-[800px] rounded-full bg-blue-500/[0.07] dark:bg-blue-500/[0.09] blur-[80px]"></div>
			</div>
		)}
		<Navbar hasTabs={hasTabs}><slot name="tabs" slot="default" /></Navbar>
		<slot />
		{!hideFooter && <Footer />}
		<CodeBlocks client:only="preact" />
	</body>
</html>
