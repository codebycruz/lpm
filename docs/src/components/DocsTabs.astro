---
export interface DocsTab {
	label: string;
	id: string;
	firstHref: string;
}

interface Props {
	tabs: DocsTab[];
	activeTab: string;
}

const { tabs, activeTab } = Astro.props;
---

<div class="flex w-full lg:w-7xl mx-auto px-4 md:px-8 overflow-x-auto -mb-px">
	{tabs.map((tab) => (
		<a
			href={tab.firstHref}
			class:list={[
				"shrink-0 px-4 py-2.5 text-sm font-medium border-b-2 transition-colors",
				tab.id === activeTab
					? "border-blue-500 text-blue-600 dark:text-blue-400"
					: "border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100",
			]}
		>
			{tab.label}
		</a>
	))}
</div>
